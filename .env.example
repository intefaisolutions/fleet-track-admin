# Local development
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_PUBLIC_URL=http://localhost:5173

# Production (Swagger UI: https://fleettrackservice.in/api/docs)
# VITE_API_BASE_URL=https://fleettrackservice.in/api/v1
# VITE_APP_PUBLIC_URL=https://fleettrackservice.in

# Google Sign-In (same OAuth Web Client ID as backend GOOGLE_CLIENT_ID)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional — footer "Contact Support" mailto on auth pages
# VITE_SUPPORT_EMAIL=support@fleettrackservice.in
